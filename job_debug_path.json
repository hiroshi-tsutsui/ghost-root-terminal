{
  "taskGroups": [
    {
      "taskSpec": {
        "runnables": [
          {
            "container": {
              "imageUri": "us-central1-docker.pkg.dev/dev-dotsfty/yolo/yolo:latest",
              "entrypoint": "bash",
              "commands": [
                "-c",
                "echo 'Listing /app structure:' && find /app -maxdepth 4 -not -path '*/.*' && echo 'Listing /mnt/disks/patch:' && ls -R /mnt/disks/patch"
              ],
              "volumes": [
                "/mnt/disks/patch:/mnt/disks/patch:ro"
              ]
            }
          }
        ],
        "computeResource": {
          "cpuMilli": "2000",
          "memoryMib": "2000"
        },
        "maxRunDuration": "600s",
        "volumes": [
          {
            "gcs": {
              "remotePath": "dotsfty-ml-experiments-src/james_temp/"
            },
            "mountPath": "/mnt/disks/patch"
          }
        ]
      },
      "taskCount": 1,
      "parallelism": 1
    }
  ],
  "allocationPolicy": {
    "instances": [
      {
        "policy": {
          "machineType": "n1-standard-4",
          "accelerators": [
            {
              "type": "nvidia-tesla-t4",
              "count": 1
            }
          ],
          "bootDisk": {
            "type": "pd-balanced",
            "sizeGb": 50
          }
        },
        "installGpuDrivers": true
      }
    ]
  },
  "logsPolicy": {
    "destination": "CLOUD_LOGGING"
  }
}
